      "fallbackOutputPath": "$taskDir/working/草稿-v1.md"
    },
    {
      "id": "prompt",
      "name": "自由 Prompt",
      "icon": "💬",
      "type": "text",
      "steps": [],
      "outputType": "stdout"
    }
  ]
}
